# ==============================================================================
# FlavourConnect — Environment Configuration Template
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every value marked REQUIRED
#   3. Generate secrets with:  make gen-secret
#   4. NEVER commit .env to version control
#   5. Validate your config with:  make env-check
#
# This file is safe to commit — it contains no real secrets.
# ==============================================================================


# ── Application ───────────────────────────────────────────────────────────────

# Environment: production | development | testing
# REQUIRED — controls error reporting, logging verbosity
APP_ENV=production

# Full public URL of this API server (no trailing slash)
# REQUIRED — used in JWT issuer claim and file URL generation
# Development: http://localhost:8000
# Production:  https://api.yourdomain.com
APP_URL=https://api.yourdomain.com

# PHP timezone string
# See: https://www.php.net/manual/en/timezones.php
APP_TIMEZONE=UTC


# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection details
# REQUIRED — all five values must be set

DB_HOST=localhost
DB_PORT=5432
DB_NAME=flavourconnect
DB_USER=fc_user

# REQUIRED — use a strong, randomly generated password
# Generate: openssl rand -base64 32
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD


# ── JWT Authentication ────────────────────────────────────────────────────────

# REQUIRED — must be at least 64 characters of random data
# Generate: openssl rand -hex 64
#
# Changing this value invalidates ALL existing sessions immediately.
# Keep a backup in your secrets manager before rotating.
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING

# Access token lifetime in seconds
# Default: 900 (15 minutes)
# Do not increase beyond 3600 in production — short expiry limits damage
# from token theft
JWT_ACCESS_TTL=900

# Refresh token lifetime in seconds
# Default: 1209600 (14 days)
# Decrease for higher-security deployments
JWT_REFRESH_TTL=1209600


# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins — NO wildcards, NO trailing slashes
# REQUIRED
#
# Development:  http://localhost:3000,http://127.0.0.1:5500
# Production:   https://yourdomain.com,https://app.yourdomain.com
#
# Any origin not in this list receives HTTP 403 on preflight.
CORS_ALLOWED_ORIGINS=https://yourdomain.com


# ── WebSocket Server ──────────────────────────────────────────────────────────

# Public port the Ratchet WebSocket server listens on
# Default: 8080
# In production this is proxied by Nginx (wss://ws.yourdomain.com → :8080)
WS_PORT=8080

# Internal HTTP URL used by the REST API to push events to the WS server
# Must be reachable from the PHP API process — keep on localhost
# The path must end in /internal
WS_INTERNAL_URL=http://localhost:8081/internal

# REQUIRED — shared secret between REST API and WebSocket server
# Verified server-side with hash_equals() to prevent timing attacks
# Generate: openssl rand -hex 32
WS_INTERNAL_SECRET=REPLACE_WITH_STRONG_WS_SECRET

# Internal HTTP port the WS server's broadcast endpoint listens on
# Never expose this port publicly — firewall it to localhost only
WS_INTERNAL_PORT=8081


# ── Networking ────────────────────────────────────────────────────────────────

# Comma-separated IPs of trusted reverse proxies (Nginx, load balancers)
# The rate limiter trusts X-Forwarded-For only from these addresses.
# For no proxy: leave as 127.0.0.1,::1
# For multiple proxies: 127.0.0.1,::1,10.0.0.1
TRUSTED_PROXIES=127.0.0.1,::1


# ── File Uploads ──────────────────────────────────────────────────────────────

# Absolute path to the upload directory
# REQUIRED — must be writable by the web server process (www-data)
#
# SECURITY: This path must be OUTSIDE the web root so uploaded files
# cannot be accessed directly via URL. The API serves them through PHP.
#
# Development: /tmp/fc_uploads
# Production:  /var/www/flavourconnect-uploads  (outside /var/www/html)
UPLOAD_PATH=/var/www/flavourconnect-uploads

# Maximum upload size in bytes
# Default: 2097152 (2 MB)
# Must also be set in php.ini: upload_max_filesize and post_max_size
UPLOAD_MAX_SIZE=2097152
