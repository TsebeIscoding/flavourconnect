# ==============================================================================
# FlavourConnect — Development Environment Template
#
# INSTRUCTIONS:
#   cp .env.dev.example .env
#
# This file has safe development defaults pre-filled so you can get running
# quickly. You still need to generate secrets for JWT_SECRET and
# WS_INTERNAL_SECRET — do not use placeholder values.
#
# DO NOT use these settings in production.
# ==============================================================================


# ── Application ───────────────────────────────────────────────────────────────

APP_ENV=development
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC


# ── Database ──────────────────────────────────────────────────────────────────

DB_HOST=localhost
DB_PORT=5432
DB_NAME=flavourconnect
DB_USER=fc_user

# Set this to whatever password you used in:
#   CREATE USER fc_user WITH PASSWORD '...';
DB_PASSWORD=devpassword


# ── JWT Authentication ────────────────────────────────────────────────────────

# REQUIRED — generate with: make gen-secret
JWT_SECRET=REPLACE_WITH_OUTPUT_OF_MAKE_GEN_SECRET

JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600


# ── CORS ──────────────────────────────────────────────────────────────────────

# Allow common local dev servers
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:5500,http://127.0.0.1:3000


# ── WebSocket Server ──────────────────────────────────────────────────────────

WS_PORT=8080
WS_INTERNAL_URL=http://localhost:8081/internal
WS_INTERNAL_PORT=8081

# REQUIRED — generate with: openssl rand -hex 32
WS_INTERNAL_SECRET=REPLACE_WITH_OUTPUT_OF_OPENSSL_RAND


# ── Networking ────────────────────────────────────────────────────────────────

TRUSTED_PROXIES=127.0.0.1,::1


# ── File Uploads ──────────────────────────────────────────────────────────────

# /tmp is fine for development — writable without root
UPLOAD_PATH=/tmp/fc_uploads
UPLOAD_MAX_SIZE=2097152
